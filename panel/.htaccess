<Files "r2-config.php">
	<IfModule mod_authz_core.c>
		Require all denied
	</IfModule>
	<IfModule !mod_authz_core.c>
		Order deny,allow
		Deny from all
	</IfModule>
</Files>

RewriteEngine On
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d

#RewriteCond %{HTTPS} off
#RewriteRule .* https://%{HTTP_HOST}%{REQUEST_URI} 																				[L,R=301]
#RewriteCond %{HTTP_HOST} !^www\. 																								[NC]
#RewriteRule .* https://www.%{HTTP_HOST}%{REQUEST_URI} 																			[L,R=301]


RewriteRule ^vitrin-urun-ekle/([0-9]*)$								index.php?sayfa=vitrin-urun-ekle&vitrin_id=$1					[L]
RewriteRule ^vitrin-urun-ekle/([0-9]*)/sil/([0-9]*)$				index.php?sayfa=vitrin-urun-ekle&vitrin_id=$1&sil_id=$2			[L]


RewriteRule ^vitrin-urun-ekle1/([0-9]*)$							index.php?sayfa=vitrin-urun-ekle1&vitrin_id=$1					[L]
RewriteRule ^vitrin-urun-ekle1/([0-9]*)/sil/([0-9]*)$				index.php?sayfa=vitrin-urun-ekle1&vitrin_id=$1&sil_id=$2			[L]


RewriteRule ^siparis/([0-9]*)/([0-9]*)$								index.php?sayfa=siparis&no=$1&sil_id=$2							[L]

RewriteRule ^([A-Za-z0-9-]+)$										index.php?sayfa=$1&no=1											[L]
RewriteRule ^([A-Za-z0-9-]+)/([0-9]*)$								index.php?sayfa=$1&no=$2										[L]
RewriteRule ^([A-Za-z0-9-]+)/duzenle/([0-9]*)$						index.php?sayfa=$1&duzenle_id=$2								[L]
RewriteRule ^([A-Za-z0-9-]+)/sil/([0-9]*)$							index.php?sayfa=$1&sil_id=$2&no=1								[L]

#ErrorDocument 404 https://www.webyazilimajansi.com/sym/index.php